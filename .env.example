# Copy to .env and fill in. On cPanel you can instead set these as
# "Environment variables" in the Python App screen.

# --- Core ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=akproftom.uz,www.akproftom.uz
CSRF_TRUSTED_ORIGINS=https://akproftom.uz,https://www.akproftom.uz

# --- Database ---
# Local dev: leave DB_ENGINE=sqlite (no other DB_* needed).
# Production (cPanel): set DB_ENGINE=mysql and fill the cPanel MySQL details.
DB_ENGINE=sqlite
DB_NAME=cpaneluser_akproftom
DB_USER=cpaneluser_akprof
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=3306

# --- Media ---
# Folder Apache can serve. On cPanel point this at e.g. /home/USER/public_html/media
# MEDIA_ROOT=/home/cpaneluser/public_html/media
