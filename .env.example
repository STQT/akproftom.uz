# Copy to .env and fill in. On cPanel you can instead set these as
# "Environment variables" in the Python App screen.

# --- Core ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=akproftom.uz,www.akproftom.uz
CSRF_TRUSTED_ORIGINS=https://akproftom.uz,https://www.akproftom.uz
# Set to False until an SSL certificate is installed (otherwise the CSRF/session
# cookies are HTTPS-only and forms fail over plain HTTP). Switch to True after SSL.
USE_HTTPS=True

# --- Database ---
# Local dev: leave DB_ENGINE=sqlite (no other DB_* needed).
# Production (cPanel): set DB_ENGINE=mysql and fill the cPanel MySQL details.
DB_ENGINE=sqlite
DB_NAME=cpaneluser_akproftom
DB_USER=cpaneluser_akprof
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=3306

# --- Media ---
# Local dev: leave USE_R2=False — uploads go to the MEDIA_ROOT folder below.
# Folder Apache can serve. On cPanel point this at e.g. /home/USER/public_html/media
# MEDIA_ROOT=/home/cpaneluser/public_html/media

# --- Cloudflare R2 (media storage in production) ---
# Set USE_R2=True to store uploaded media on R2 instead of the local disk.
USE_R2=False
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=akproftom-media
# Account endpoint (Cloudflare dashboard → R2 → Manage API Tokens):
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Public URL of the bucket: enable "Public Development URL" on the bucket
# (https://pub-xxxx.r2.dev) or attach a custom domain (https://media.akproftom.uz).
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# --- Telegram bot & notifications ---
# Create a bot via @BotFather to get the token. Get the chat id via @userinfobot
# (personal chat). TELEGRAM_CHAT_ID may be one id or comma-separated.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Bot runs via WEBHOOK (cPanel can't keep a polling process alive). Webhook
# needs HTTPS, so fill these only after SSL is installed, then run:
#   python manage.py set_webhook
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-long-random-string
TELEGRAM_WEBHOOK_BASE=https://akproftom.uz
# Mini App: HTTPS URL opened inside Telegram as a "web_app" button. Usually the
# site root. Leave empty until SSL is live.
TELEGRAM_WEBAPP_URL=https://akproftom.uz
